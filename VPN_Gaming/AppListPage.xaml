<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="VPN_Gaming.AppListPage"
             BackgroundColor="#FFFFFF">

    <Grid>
        <Grid RowDefinitions="Auto, Auto, *" Padding="20">

            <!-- زر التجميد الكلي -->
            <Button Grid.Row="0" x:Name="ExecuteFreezeAllButton" Text="تجميد الكل ❄️" 
                    BackgroundColor="#1A73E8" TextColor="White" CornerRadius="10" 
                    Margin="0,0,0,15" IsVisible="False" Clicked="OnExecuteFreezeAllClicked"/>

            <SearchBar Grid.Row="1" x:Name="AppSearchBar" Placeholder="البحث عن العناصر..." 
                       PlaceholderColor="#888888" TextColor="#202124" BackgroundColor="#F0F4F9" 
                       CancelButtonColor="#1A73E8" TextChanged="OnSearchBarTextChanged" Margin="0,0,0,15"/>

            <CollectionView Grid.Row="2" x:Name="AllAppsListView" VerticalScrollBarVisibility="Always">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Grid Padding="10,15" ColumnDefinitions="Auto, *, Auto" ColumnSpacing="15" BackgroundColor="Transparent">
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnAppRowTapped" />
                            </Grid.GestureRecognizers>

                            <Image Grid.Column="0" Source="{Binding AppIcon}" WidthRequest="35" HeightRequest="35" VerticalOptions="Center"/>
                            <Label Grid.Column="1" Text="{Binding AppName}" TextColor="#202124" VerticalOptions="Center" FontSize="16"/>

                            <!-- يظهر فقط في وضع الـ VPN -->
                            <Switch Grid.Column="2" IsToggled="{Binding IsUISelected}" OnColor="#1A73E8" InputTransparent="True" IsVisible="{Binding IsSwitchVisible}"/>
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Grid>

        <!-- نافذة التنبيهات الموحدة لهذه الصفحة -->
        <Grid x:Name="LocalAlertOverlay" BackgroundColor="#B3000000" IsVisible="False">
            <Border BackgroundColor="White" WidthRequest="300" VerticalOptions="Center" HorizontalOptions="Center" Padding="25" Stroke="Transparent">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="15"/>
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="15">
                    <Label x:Name="LocalAlertTitle" Text="تنبيه" FontSize="20" FontAttributes="Bold" TextColor="#202124" HorizontalOptions="Center" />
                    <Label x:Name="LocalAlertMessage" Text="..." FontSize="14" TextColor="#5F6368" HorizontalTextAlignment="Center" LineHeight="1.5" />
                    <Button Text="حسناً" BackgroundColor="#1A73E8" TextColor="White" CornerRadius="8" HeightRequest="45" FontAttributes="Bold" Clicked="OnCloseLocalAlertClicked" Margin="0,10,0,0"/>
                </VerticalStackLayout>
            </Border>
        </Grid>
    </Grid>
</ContentPage>